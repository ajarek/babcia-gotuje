rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
    }
    match /menu/{itemId} {
      allow read: if true;
      allow write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /reservations/{resId} {
      allow read, write: if true;
    }
  }
}
